# Copy to .env and edit. docker-compose.yml reads every variable from
# this file and forwards it to the backend container.

# --- Required for any real work ---
GEMINI_API_KEY=your-gemini-api-key
# Generate a real one for production: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me-to-a-long-random-string

# --- Optional: real Google Sign-in ---
# Leave blank to use the built-in dev login form on /login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Tunables ---
GEMINI_MODEL=gemini-2.5-flash
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Where the frontend finds the backend ---
# - "http://localhost:8000"   →  browser reaches the backend directly
# - "http://backend:8000"     →  browser talks to the backend through the
#                               frontend's rewrite (same-origin)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Misc ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
